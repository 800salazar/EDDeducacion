# ============================================================================
#  Variables de entorno — BNI EDD Insights
# ----------------------------------------------------------------------------
#  Cómo usar este archivo:
#    1. Cópialo a ".env.local"   ->   cp .env.example .env.local
#    2. Llena los 4 valores de abajo (instrucciones de dónde sacarlos).
#    3. NUNCA subas ".env.local" a git (ya está ignorado).
#
#  Estas mismas 4 variables se cargan también en Vercel para producción.
#  Guía detallada con capturas de menús: ver CONFIGURACION.md
# ============================================================================


# 1) URL del proyecto Supabase  ───────────────────────────────────────────────
#    Supabase  ->  Project Settings (engranaje)  ->  Data API
#    Campo: "Project URL"  (termina en .supabase.co)
#    Es pública (se usa en el navegador). OK que sea visible.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co


# 2) Llave pública (anon)  ────────────────────────────────────────────────────
#    Supabase  ->  Project Settings  ->  API Keys
#      - Si ves la pestaña "Legacy API keys": copia la llave  "anon" / "public".
#      - Si tu panel ya usa llaves nuevas: copia la "Publishable key"
#        (empieza con  sb_publishable_... ).  Ambas funcionan aquí.
#    Es pública por diseño (RLS solo permite LEER). OK que sea visible.
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key


# 3) Llave secreta (service_role)  ⚠️ SECRETA  ────────────────────────────────
#    Supabase  ->  Project Settings  ->  API Keys
#      - Pestaña "Legacy API keys": copia la llave  "service_role".
#      - Llaves nuevas: copia una  "Secret key"  ( sb_secret_... ).
#    NUNCA la pongas en el navegador ni la subas a git. Solo vive en el servidor.
#    (Por eso NO lleva el prefijo NEXT_PUBLIC_.)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-o-secret-key


# 4) Contraseña del panel /admin  ⚠️ SECRETA  ─────────────────────────────────
#    La inventas tú. Es la que usarás para entrar a /admin.
#    Tú eres el único administrador. Elige algo fuerte.
ADMIN_PASSWORD=cambia-esta-contraseña-por-una-fuerte
